{
  "expo": {
    "name": "Barakeat Surprise Baskets",
    "slug": "barakeat-surprise-baskets",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "barakeat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "tn.barakeat.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "tn.barakeat.app",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://barakeat.tn/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-localization",
      "expo-navigation-bar",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Barakeat to access your photos to upload images.",
          "cameraPermission": "Allow Barakeat to access your camera to take photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Barakeat to use your location to find nearby baskets."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Barakeat to use your camera to scan QR codes for order pickup."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#114b3c"
        }
      ],
      "expo-apple-authentication",
      "./plugins/withRemovePermissions"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://barakeat.tn/"
      },
      "eas": {
        "projectId": "d3b5c7d2-49f2-4de1-bfe8-f6146c2576e8"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d3b5c7d2-49f2-4de1-bfe8-f6146c2576e8"
    },
    "owner": "smzd"
  }
}
